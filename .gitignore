# Rust build output
target/

# Packaged application output
dist/

# Local runtime data generated beside development binaries
data/
**/data/settings.json
**/data/snippets.json

# OS metadata
.DS_Store
Thumbs.db

# Editor and IDE state
.vscode/*
!.vscode/
!.vscode/tasks.json
.idea/
*.swp
*.swo

# Logs and local environment files
*.log
.env
.env.*

# Temporary files
*.tmp
*.bak

# Private local security-review harnesses (reports are already under dist/)
/Scripts/*security-review*.ps1

# Shared build policy is required by the tracked Windows packaging script
!/Scripts/security-review-policy.ps1
